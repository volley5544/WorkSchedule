rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn() && role() == 'admin';
    }

    function canEdit() {
      return signedIn() && role() in ['admin', 'editor'];
    }

    // User profiles. Anyone signed in can read (names are shown on the
    // roster). A user may create their own profile but only as 'viewer';
    // only admins can change roles.
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if request.auth.uid == uid
                    && request.resource.data.role == 'viewer';
      allow update: if isAdmin()
                    || (request.auth.uid == uid
                        && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // The schedule itself is public so visitors can view the roster without
    // an account (the app offers a view-only guest mode). Writes still
    // require the editor/admin role.

    // Shifts: writable by editors/admins.
    match /shifts/{shiftId} {
      allow read: if true;
      allow create, update, delete: if canEdit();
    }

    // Read-only baseline snapshot of the auto-generated roster. Written only
    // by the auto-scheduler (editors/admins); kept separate from `shifts` so
    // the original survives shift swaps. Public read like the live roster.
    match /originalShifts/{shiftId} {
      allow read: if true;
      allow create, update, delete: if canEdit();
    }

    // Shift type config (code, hours, color): managed only by admins.
    match /shiftTypes/{typeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Pharmacist roster list: managed only by admins.
    match /pharmacists/{pharmacistId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Clinic holidays (closed days): shown on the public calendar, managed
    // only by admins.
    match /holidays/{holidayId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Misc app config (e.g. the name-title list): managed only by admins.
    match /config/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
