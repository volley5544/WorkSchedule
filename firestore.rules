rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn() && role() == 'admin';
    }

    function canEdit() {
      return signedIn() && role() in ['admin', 'editor'];
    }

    // User profiles. Anyone signed in can read (names are shown on the
    // roster). A user may create their own profile but only as 'viewer';
    // only admins can change roles.
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if request.auth.uid == uid
                    && request.resource.data.role == 'viewer';
      allow update: if isAdmin()
                    || (request.auth.uid == uid
                        && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // Shifts: readable by all signed-in users, writable by editors/admins.
    match /shifts/{shiftId} {
      allow read: if signedIn();
      allow create, update, delete: if canEdit();
    }
  }
}
